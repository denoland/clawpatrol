{
  "action": {
    "host": "build.example.com:2222",
    "ssh": {
      "verb": "shell",
      "user": "ubuntu"
    }
  },
  "match": {
    "verdict":  "deny",
    "rule":     "ssh-no-interactive",
    "endpoint": "ssh.build-host",
    "reason":   "interactive sessions are not permitted; run a command instead"
  }
}
