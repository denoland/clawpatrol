{
  "defaults": {
    "human_on_timeout": "deny",
    "human_timeout": 600,
    "llm_cache_ttl": 300,
    "llm_fail_mode": "closed",
    "unknown_host": "passthrough"
  },
  "gateway": {
    "dashboard_listen": "0.0.0.0:8080",
    "log_path": "/opt/clawpatrol/gateway.log",
    "public_url": "http://66.42.120.196:8080",
    "state_dir": "/opt/clawpatrol/oauth",
    "wireguard": {
      "endpoint": "0.0.0.0:51820",
      "subnet_cidr": "10.55.0.0/24"
    }
  },
  "policy": {
    "approvers": {
      "human_approver.ops": {
        "body": {
          "Channel": "#agent-ops",
          "Credential": "",
          "Timeout": 600,
          "RequireApprovers": 0,
          "Interactive": false,
          "Classifier": "",
          "Message": ""
        },
        "type": "human_approver"
      }
    },
    "credentials": {
      "bearer_token.github": {
        "body": {
          "IdempotencyKey": false
        },
        "endpoint": "https.github",
        "type": "bearer_token"
      }
    },
    "endpoints": {
      "https.github": {
        "body": {
          "Hosts": [
            "api.github.com",
            "github.com"
          ]
        },
        "family": "http",
        "type": "https"
      }
    },
    "profiles": {
      "default": {
        "credentials": [
          "bearer_token.github"
        ]
      }
    },
    "rules": {
      "github-reads": {
        "body": {
          "name": "github-reads",
          "family": "http",
          "endpoints": [
            "https.github"
          ],
          "condition": "http.method in ['GET', 'HEAD']",
          "verdict": "allow"
        }
      },
      "github-writes": {
        "body": {
          "name": "github-writes",
          "family": "http",
          "endpoints": [
            "https.github"
          ],
          "condition": "http.method in ['POST', 'PUT', 'PATCH', 'DELETE']",
          "approve": [
            {
              "name": "human_approver.ops"
            }
          ]
        }
      }
    }
  }
}
