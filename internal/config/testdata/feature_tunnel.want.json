{
  "gateway": {
    "public_url": "https://gw.example.test",
    "state_dir": "/opt/clawpatrol",
    "wireguard": {
      "subnet_cidr": "10.55.0.0/24"
    }
  },
  "policy": {
    "credentials": {
      "bearer_token.github": {
        "body": {
          "IdempotencyKey": false
        },
        "endpoints": [
          "https.github",
          "postgres.deploy-classic"
        ],
        "type": "bearer_token"
      }
    },
    "endpoints": {
      "https.github": {
        "body": {
          "Hosts": [
            "api.github.com",
            "github.com"
          ]
        },
        "family": "http",
        "type": "https"
      },
      "postgres.deploy-classic": {
        "body": {
          "Host": "main-pg14.classic.example:5432",
          "SSLMode": ""
        },
        "family": "sql",
        "tunnel": "local_command.csql-prod",
        "type": "postgres"
      }
    },
    "profiles": {
      "default": {
        "credentials": [
          "bearer_token.github"
        ]
      }
    },
    "tunnels": {
      "local_command.csql-prod": {
        "body": {
          "Command": [
            "cloud_sql_proxy",
            "--enable_iam_login",
            "--instances",
            "example-project:us-central1:main-pg14=tcp:5432"
          ],
          "Listen": "127.0.0.1:5432",
          "ReadyProbe": "tcp",
          "ReadyTimeout": "30s",
          "Env": null,
          "Share": "singleton",
          "Keepalive": "5m",
          "Via": "",
          "Credential": ""
        },
        "type": "local_command"
      }
    }
  }
}
