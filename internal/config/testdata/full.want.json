    "rules": {
      "clickhouse-default": {
        "body": {
          "name": "clickhouse-default",
          "family": "sql",
          "endpoints": [
            "clickhouse_https.ch-o11y-https",
            "clickhouse_native.ch-o11y-native"
          ],
          "priority": -100,
          "verdict": "deny",
          "reason": "ClickHouse access is read-only"
        }
      },
      "clickhouse-reads": {
        "body": {
          "name": "clickhouse-reads",
          "family": "sql",
          "endpoints": [
            "clickhouse_https.ch-o11y-https",
            "clickhouse_native.ch-o11y-native"
          ],
          "condition": "sql.verb in ['select', 'show', 'describe', 'explain', 'use']",
          "verdict": "allow"
        }
      },
      "grafana-annotations-snapshots": {
        "body": {
          "name": "grafana-annotations-snapshots",
          "family": "http",
          "endpoints": [
            "https.grafana"
          ],
          "condition": "http.method == 'POST' && http.path in ['/api/annotations', '/api/snapshots']",
          "verdict": "allow"
        }
      },
      "grafana-dashboard-writes": {
        "body": {
          "name": "grafana-dashboard-writes",
          "family": "http",
          "endpoints": [
            "https.grafana"
          ],
          "condition": "http.method in ['POST', 'PUT', 'PATCH'] && (http.path.startsWith('/api/dashboards/') || http.path.startsWith('/api/datasources/') || http.path.startsWith('/api/folders/') || http.path.startsWith('/api/alert-rules/'))",
          "approve": [
            {
              "name": "human_approver.observability"
            }
          ]
        }
      },
      "grafana-no-destructive-deletes": {
        "body": {
          "name": "grafana-no-destructive-deletes",
          "family": "http",
          "endpoints": [
            "https.grafana"
          ],
          "condition": "http.method == 'DELETE' && (http.path.startsWith('/api/dashboards/') || http.path.startsWith('/api/datasources/') || http.path.startsWith('/api/folders/') || http.path.startsWith('/api/alert-rules/'))",
          "verdict": "deny",
          "reason": "Destructive deletes go through a PR, not the agent"
        }
      },
      "grafana-reads": {
        "body": {
          "name": "grafana-reads",
          "family": "http",
          "endpoints": [
            "https.grafana"
          ],
          "condition": "http.method in ['GET', 'HEAD']",
          "verdict": "allow"
        }
      },
      "k8s-allow-meta": {
        "body": {
          "name": "k8s-allow-meta",
          "family": "k8s",
          "endpoints": [
            "kubernetes.k8s-dev-iad",
            "kubernetes.k8s-dev-sfo",
            "kubernetes.k8s-eks-corp-prod"
          ],
          "condition": "k8s.verb == 'meta'",
          "verdict": "allow"
        }
      },
      "k8s-debug-pods": {
        "body": {
          "name": "k8s-debug-pods",
          "family": "k8s",
          "endpoints": [
